  const safeActing = String(actingName).replace(/</g, '&lt;');
  const safeAbsent = String(absentCT || '').replace(/</g, '&lt;');
  const dateLabel = plan.date + ' (' + plan.day + ')';
  return ''
    + '<div style="font-family:Arial,sans-serif;color:#1a202c;max-width:680px;margin:0 auto">'
    + '<h2 style="color:#0041a3;margin:0 0 4px">G.D. Goenka Public School, Darbhanga</h2>'
    + '<div style="background:linear-gradient(135deg,#92400e 0%,#d97706 100%);color:#fff;padding:6px 12px;border-radius:4px;text-align:center;letter-spacing:1.5px;font-weight:700;margin:6px 0 14px">ACTING CLASS TEACHER</div>'
    + '<p>Dear <b>' + safeActing + '</b>,</p>'
    + '<p>You have been designated <b>Acting Class Teacher for ' + safeCls + '</b> on <b>' + dateLabel + '</b>'
    + (safeAbsent ? ', covering for <b>' + safeAbsent + '</b> (absent today)' : '') + '.</p>'
    + '<p><b>Responsibilities for the day:</b></p>'
    + '<ul style="line-height:1.65">'
    + '<li>Morning attendance and line-up</li>'
    + '<li>Discipline and pastoral care during the school day</li>'
    + '<li>Lunch supervision and dispersal handover</li>'
    + '<li>Any parent / front-office communication routed to the class teacher</li>'
    + '</ul>'
    + '<p style="background:#fefce8;border:1px solid #fde68a;padding:10px 14px;border-radius:6px;color:#92400e">'
    + '<b>Note:</b> period substitution duties, if any, are listed separately in the daily substitution memo. '
    + 'The acting-CT role is independent of teaching coverage.</p>'
    + '<p style="color:#6b7280;font-size:.85em;margin-top:18px">Issued by: ' + String(sentBy || '').replace(/</g, '&lt;') + '<br>'
    + 'Automated via GDGPSD Substitution Planner.</p>'
    + '</div>';
}

// v3.12 — HTML email body for a substitute teacher's daily slot list
function _renderSubEmail(plan, subName, slots, sentBy) {
  const sorted = slots.slice().sort((a,b) => (+a.period) - (+b.period));
  let rows = '';
  for (const s of sorted) {
    const subjLine = String(s.subject || '').replace(/</g, '&lt;');
    const cls = String(s.class || '').replace(/</g, '&lt;');
    const absent = String(s.absent || '').replace(/</g, '&lt;');
    const note = s.note ? '<div style="font-size:.8em;color:#6b7280">Note: ' + String(s.note).replace(/</g, '&lt;') + '</div>' : '';
    const tag = s.status === 'SUPERVISED' ? '<span style="background:#ede9fe;color:#5b21b6;padding:2px 8px;border-radius:999px;font-size:.75em;font-weight:600">SUPERVISION</span>' : '';
    rows += '<tr>' +
      '<td style="padding:8px;border:1px solid #d1d5db;text-align:center;font-weight:700;color:#0041a3">P' + s.period + '</td>' +
      '<td style="padding:8px;border:1px solid #d1d5db"><b>' + cls + '</b></td>' +
      '<td style="padding:8px;border:1px solid #d1d5db">' + subjLine + '</td>' +
      '<td style="padding:8px;border:1px solid #d1d5db">' + absent + ' ' + tag + note + '</td>' +
      '</tr>';
  }
  const dateLabel = plan.date;
  return ''
    + '<div style="font-family:Arial,sans-serif;color:#1a202c;max-width:680px;margin:0 auto">'
    + '<h2 style="color:#0041a3;margin:0 0 4px">G.D. Goenka Public School, Darbhanga</h2>'
    + '<div style="background:linear-gradient(135deg,#0041a3 0%,#1a5fdb 100%);color:#fff;padding:6px 12px;border-radius:4px;text-align:center;letter-spacing:1.5px;font-weight:700;margin:6px 0 14px">SUBSTITUTION DUTY</div>'
    + '<p>Dear <b>' + subName.replace(/</g, '&lt;') + '</b>,</p>'
    + '<p>You have been assigned the following substitution duties for <b>' + dateLabel + ' (' + plan.day + ')</b>:</p>'
    + '<table style="width:100%;border-collapse:collapse;font-size:14px"><thead>'
    + '<tr style="background:#0041a3;color:#fff"><th style="padding:8px;border:1px solid #0041a3;text-align:center">Period</th>'
    + '<th style="padding:8px;border:1px solid #0041a3">Class</th>'
    + '<th style="padding:8px;border:1px solid #0041a3">Subject</th>'
    + '<th style="padding:8px;border:1px solid #0041a3">Covering for</th></tr></thead>'
    + '<tbody>' + rows + '</tbody></table>'
    + '<p style="margin-top:18px">Please reach the class on time. If you anticipate any conflict, contact the principal\'s office immediately.</p>'
    + '<p style="color:#6b7280;font-size:.85em;margin-top:18px">Issued by: ' + sentBy.replace(/</g, '&lt;') + '<br>'
    + 'Automated via GDGPSD Substitution Planner.</p>'
    + '</div>';
}

// =============================================================
// Draft state — cross-admin persistence
// One row per date in tab 'Daily Drafts': Date | Day | Updated At | Updated By | Absent JSON | Slots JSON
// =============================================================
function loadDraft(date, token) {
  _requireAuth(token);
  if (!date) return null;
  // v3.12 — also pull any active long absences for this date
  const longAbsences = loadLongAbsencesForDate(date, token);
  // v3.13 — pull reschedule rules
  const rescheduleRules = loadRescheduleRules(token);
  const sh = SpreadsheetApp.getActive().getSheetByName(DRAFTS_TAB);
  let base = null;
  if (sh) {
    const data = sh.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      const rowDate = data[i][0] instanceof Date
        ? Utilities.formatDate(data[i][0], 'Asia/Kolkata', 'yyyy-MM-dd')
        : String(data[i][0]).slice(0, 10);
      if (rowDate !== date) continue;
      try {
        const updatedAt = data[i][2] instanceof Date
          ? Utilities.formatDate(data[i][2], 'Asia/Kolkata', "yyyy-MM-dd HH:mm:ss")
          : String(data[i][2] || '');
        let dutyPool = [];
        try { dutyPool = JSON.parse(data[i][6] || '[]'); } catch (e) {}
        // v3.18 — Acting CT JSON in column 8 (backwards-compat: legacy rows are missing this).
        let actingCT = {};
        try { actingCT = JSON.parse(data[i][7] || '{}'); } catch (e) {}
        base = {
          date: date,
          day: data[i][1],
          updatedAt: updatedAt,
          updatedBy: String(data[i][3] || ''),
          absent: JSON.parse(data[i][4] || '[]'),
          slots: JSON.parse(data[i][5] || '[]'),
          dutyPool: dutyPool,
          actingCT: actingCT,
          longAbsences: longAbsences,
          rescheduleRules: rescheduleRules,
        };
      } catch (e) {}
      break;
    }
  }
  if (!base) {
    // No draft for this date — but still return long absences / rules so the UI can populate them
    if (longAbsences.length > 0 || rescheduleRules.length > 0)
      return { date: date, day: '', absent: [], slots: [], dutyPool: [], longAbsences: longAbsences, rescheduleRules: rescheduleRules };
    return null;
  }
  return base;
}

function saveDraft(draft, token) {
  const verifiedName = _requireAuth(token);
  // Override updatedBy with the server-verified name (don't trust client-supplied value)
  draft = Object.assign({}, draft, { updatedBy: verifiedName });
  const ss = SpreadsheetApp.getActive();
  let sh = ss.getSheetByName(DRAFTS_TAB);
  if (!sh) {
    sh = ss.insertSheet(DRAFTS_TAB);
    sh.getRange(1, 1, 1, 8).setValues([['Date','Day','Updated At','Updated By','Absent JSON','Slots JSON','Duty Pool JSON','Acting CT JSON']])
      .setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
    sh.setFrozenRows(1);
    sh.setColumnWidth(1, 95); sh.setColumnWidth(2, 60); sh.setColumnWidth(3, 150);
    sh.setColumnWidth(4, 130); sh.setColumnWidth(5, 280); sh.setColumnWidth(6, 600); sh.setColumnWidth(7, 200); sh.setColumnWidth(8, 240);
  }
  // Legacy migrations — add missing columns
  if (sh.getLastColumn() < 7) {
    sh.getRange(1, 7, 1, 1).setValue('Duty Pool JSON').setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
  }
  if (sh.getLastColumn() < 8) {
    sh.getRange(1, 8, 1, 1).setValue('Acting CT JSON').setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
  }
  const ts = new Date();
  const tsStr = Utilities.formatDate(ts, 'Asia/Kolkata', "yyyy-MM-dd HH:mm:ss");
  const updatedBy = String(draft.updatedBy || 'admin').slice(0, 60);
  const row = [draft.date, draft.day || '', tsStr, updatedBy,
               JSON.stringify(draft.absent || []), JSON.stringify(draft.slots || []),
               JSON.stringify(draft.dutyPool || []),
               JSON.stringify(draft.actingCT || {})];
  const data = sh.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    const rowDate = data[i][0] instanceof Date
      ? Utilities.formatDate(data[i][0], 'Asia/Kolkata', 'yyyy-MM-dd')
      : String(data[i][0]).slice(0, 10);
    if (rowDate === draft.date) {
      sh.getRange(i + 1, 1, 1, 8).setValues([row]);
      return {success: true, updatedAt: tsStr, updatedBy};
    }
  }
  sh.appendRow(row);
  return {success: true, updatedAt: tsStr, updatedBy};
}

