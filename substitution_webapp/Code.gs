// ---- Read 'Substitution Log' for the last 7 days → cumulative extras per teacher ----
// v3.10 — Drafts-first counting: for each past-7-days date, prefer the live
// Daily Drafts state (so clearing a slot drops the count immediately, without
// requiring a re-Publish). Falls back to Substitution Log for dates that
// were never opened in the planner this week.
function loadWeeklyLoad() {
  const ss = SpreadsheetApp.getActive();
  const sevenDaysAgo = new Date();
  sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

  function normDate(d) {
    if (d instanceof Date) return Utilities.formatDate(d, 'Asia/Kolkata', 'yyyy-MM-dd');
    return String(d || '').slice(0, 10);
  }

  // Pass 1: read Daily Drafts. For each past-7-days date with a draft, count FILLED
  // substitutions from its slots JSON. Record which dates are covered by drafts.
  const weekly = {};
  const draftDates = {};
  const draftsSh = ss.getSheetByName(DRAFTS_TAB);
  if (draftsSh && draftsSh.getLastRow() > 1) {
    const draftData = draftsSh.getDataRange().getValues();
    // Header: Date | Day | Updated At | Updated By | Absent JSON | Slots JSON
    for (let i = 1; i < draftData.length; i++) {
      const dateStr = normDate(draftData[i][0]);
      if (!dateStr) continue;
      const d = new Date(dateStr);
      if (isNaN(d.getTime()) || d < sevenDaysAgo) continue;
      let slots = [];
      try { slots = JSON.parse(draftData[i][5] || '[]'); } catch (e) { continue; }
      draftDates[dateStr] = true;
      for (const s of slots) {
        if ((s.status === 'FILLED' || s.status === 'SUPERVISED') && s.substitute) {
          weekly[s.substitute] = (weekly[s.substitute] || 0) + 1;
        }
      }
    }
  }

  // Pass 2: read Substitution Log. Count only dates NOT covered by drafts —
  // these are historical, never-edited dates (e.g. older substitutions you
  // haven't revisited this week).
  const logSh = ss.getSheetByName(LOG_TAB);
  if (logSh && logSh.getLastRow() > 1) {
    const logData = logSh.getDataRange().getValues();
    for (let i = 1; i < logData.length; i++) {
      const [savedAt, date, day, period, klass, subject, absent, sub, status] = logData[i];
      if (!sub || status !== 'FILLED') continue;
      const dateStr = normDate(date);
      if (!dateStr) continue;
      const d = new Date(dateStr);
      if (isNaN(d.getTime()) || d < sevenDaysAgo) continue;
      if (draftDates[dateStr]) continue;   // already counted from drafts
      weekly[sub] = (weekly[sub] || 0) + 1;
    }
  }

  return {weekly: weekly, fromDate: sevenDaysAgo.toISOString().slice(0, 10)};
}

// ---- Build the in-memory schedule cache (read once per page load) ----
function loadDayCache() {
  const sh = SpreadsheetApp.getActive().getSheetByName(FLAT_TEACHER_TAB);
  if (!sh) throw new Error("Tab '" + FLAT_TEACHER_TAB + "' not found");
  const data = sh.getDataRange().getValues();
  // Header: Teacher | Day | Period# | Start | End | Subject | Class-Section | Room
  // v3.9 — periods, periodTimes, and days are derived from the sheet rows (not hardcoded)
  const out = {
    days: [],                   // dynamically derived
    periods: [],                // dynamically derived (sorted)
    periodTimes: {},            // dynamically derived  period → "start-end"
    teachers: [],
    teacherSubjects: {},
    teacherClasses: {},
    schedule: {},
    coTeachers: {},
    classTeachers: {},          // class → class teacher (from Class Teachers tab)
  };
  const teacherSet = new Set();
  const daysSet = new Set();
  const periodsSet = new Set();
  const tSubj = {}, tCls = {};
  for (let i = 1; i < data.length; i++) {
    const [teacher, day, period, start, end, subject, klass, room] = data[i];
    if (!teacher) continue;
    teacherSet.add(teacher);
    daysSet.add(day);
    const pStr = String(period);
    periodsSet.add(pStr);
    if (!out.periodTimes[pStr] && start && end) {
      out.periodTimes[pStr] = String(start) + '-' + String(end);
    }
    (tSubj[teacher] = tSubj[teacher] || new Set()).add(subject);
    (tCls[teacher]  = tCls[teacher]  || new Set()).add(klass);
    out.schedule[teacher] = out.schedule[teacher] || {};
    out.schedule[teacher][day] = out.schedule[teacher][day] || {};
    out.schedule[teacher][day][pStr] = {class: klass, subject: subject, room: room || ''};
    out.coTeachers[klass] = out.coTeachers[klass] || {};
    out.coTeachers[klass][day] = out.coTeachers[klass][day] || {};
    out.coTeachers[klass][day][pStr] = out.coTeachers[klass][day][pStr] || [];
    out.coTeachers[klass][day][pStr].push({teacher, subject});
  }
  // v3.20 — include teachers from the Teacher Emails roster even if they have
  // no scheduled cards (e.g. new hires not yet timetabled). They should be
  // pickable as emergency substitutes and as absent. Empty schedule = always free.
  // NOTE: read the tab directly — do NOT use _loadTeacherEmails() because it
  // filters out rows with blank email, and new hires often have no email on
  // file yet (we still want them visible as candidates).
  const _teSh = SpreadsheetApp.getActive().getSheetByName('Teacher Emails');
  if (_teSh && _teSh.getLastRow() > 1) {
    const _teData = _teSh.getRange(2, 1, _teSh.getLastRow() - 1, 1).getValues();
    for (const row of _teData) {
      const t = String((row && row[0]) || '').trim();
      if (t && !teacherSet.has(t)) {
        teacherSet.add(t);
        out.schedule[t] = {};
      }
    }
  }
  out.teachers = [...teacherSet].sort();
  out.periods = [...periodsSet].sort((a, b) => +a - +b);
  // Order days canonically (any present)
  const DAY_ORDER = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  out.days = DAY_ORDER.filter(d => daysSet.has(d));
  out.teacherSubjects = {};
  out.teacherClasses = {};
  for (const t of out.teachers) {
    out.teacherSubjects[t] = [...(tSubj[t] || new Set())];
    out.teacherClasses[t]  = [...(tCls[t]  || new Set())];
  }
  // Read Class Teachers tab (v3.9) — class → teacher name. Missing tab is OK (silent empty map).
  const ctSh = SpreadsheetApp.getActive().getSheetByName('Class Teachers');
  if (ctSh && ctSh.getLastRow() > 1) {
    const ctData = ctSh.getDataRange().getValues();
    for (let i = 1; i < ctData.length; i++) {
      const [cls, tname] = ctData[i];
      if (cls && tname) out.classTeachers[String(cls).trim()] = String(tname).trim();
    }
  }
  return out;
}

// ---- Save a published plan back to the sheet + email + memo ----
function savePlan(plan, token) {
  const verifiedName = _requireAuth(token);
  // plan = { date, day, absentTeachers, substitutions: [...], emailSubs, makeMemo }
  const ss = SpreadsheetApp.getActive();
  let log = ss.getSheetByName(LOG_TAB);
  if (!log) {
    log = ss.insertSheet(LOG_TAB);
    log.getRange(1,1,1,10).setValues([['Saved At','Date','Day','Period','Class','Subject','Absent','Substitute','Status','Saved By']])
       .setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
  }
  const ts = new Date().toISOString();
  const rows = plan.substitutions.map(s => [
    ts, plan.date, plan.day, s.period, s.class, s.subject, s.absent, s.substitute || '', s.status, verifiedName
  ]);

  // v3.18 — append ACTING_CT rows (one per absent CT with a shift assignment).
  // Use sentinels for period/subject so the dedupe key (date, period, class, absent)
  // uniquely identifies the acting-CT slot per class on a given date.
  const _actingCT = plan.actingCT || {};
  const _actingCTFor = plan.actingCTFor || {};   // class → absent CT name (sent by client)
  for (const cls of Object.keys(_actingCT)) {
    const t = _actingCT[cls];
    if (!t) continue;
    const forName = _actingCTFor[cls] || '';
    rows.push([ts, plan.date, plan.day, '', cls, 'Acting CT', forName, t, 'ACTING_CT', verifiedName]);
  }

  // v3.8 — dedupe: replace existing rows for the same (date, period, class, absent) keys
  // before appending, so republishing the same date doesn't double-count in 7-day workload.
  if (log.getLastRow() > 1) {
    const newKeys = {};
    for (const s of plan.substitutions) {
      newKeys[[plan.date, String(s.period), String(s.class), String(s.absent)].join('|')] = true;
    }
    // v3.18 — also reserve keys for acting CT rows so re-publish replaces them too
    for (const cls of Object.keys(_actingCT)) {
      newKeys[[plan.date, '', String(cls), String(_actingCTFor[cls] || '')].join('|')] = true;
    }
    const allData = log.getDataRange().getValues();
    const header = allData[0];
    const keptRows = [];
    for (let i = 1; i < allData.length; i++) {
      const r = allData[i];
      const dateCell = r[1];
      const dateStr = dateCell instanceof Date
        ? Utilities.formatDate(dateCell, 'Asia/Kolkata', 'yyyy-MM-dd')
        : String(dateCell).slice(0, 10);
      // v3.18 — drop ALL existing ACTING_CT rows for this date during rewrite.
      // The new plan's acting-CT rows are appended below; this prevents stale
      // assignments from lingering when admin un-marks an absent CT and republishes.
      if (String(r[8]) === 'ACTING_CT' && dateStr === plan.date) continue;
      const key = [dateStr, String(r[3]), String(r[4]), String(r[6])].join('|');
      if (!newKeys[key]) keptRows.push(r);
    }
    // Rewrite the log: header + kept rows + new rows
    const finalRows = [header].concat(keptRows).concat(rows);
    log.clearContents();
    log.getRange(1, 1, finalRows.length, 10).setValues(finalRows);
    // Restore header formatting
    log.getRange(1, 1, 1, 10).setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
  } else if (rows.length) {
    log.getRange(log.getLastRow() + 1, 1, rows.length, 10).setValues(rows);
  }

  // v3.12 — Email substitutes if requested
  let emailedCount = 0;
  let emailedTo = [];
  if (plan.emailSubs) {
    const bySub = {};
    for (const s of plan.substitutions) {
      if ((s.status !== 'FILLED' && s.status !== 'SUPERVISED') || !s.substitute) continue;
      (bySub[s.substitute] = bySub[s.substitute] || []).push(s);
    }
    const emails = _loadTeacherEmails();
    for (const [subName, slots] of Object.entries(bySub)) {
      const to = emails[subName];
      if (!to) continue;
      try {
        MailApp.sendEmail({
          to: to,
          cc: SUBSTITUTION_CC_EMAILS,
          subject: 'Substitution duty — ' + plan.date + ' (' + plan.day + ')',
          htmlBody: _renderSubEmail(plan, subName, slots, verifiedName),
        });
        emailedTo.push(subName);
        emailedCount++;
      } catch (e) {
        // log + continue; one teacher's email failure shouldn't block others
      }
    }
    // v3.18 — email each acting CT (one mail per class assignment)
    for (const cls of Object.keys(_actingCT)) {
      const t = _actingCT[cls];
      if (!t) continue;
      const to = emails[t];
      if (!to) continue;
      try {
        MailApp.sendEmail({
          to: to,
          cc: SUBSTITUTION_CC_EMAILS,
          subject: 'Acting Class Teacher — ' + cls + ' — ' + plan.date + ' (' + plan.day + ')',
          htmlBody: _renderActingCTEmail(plan, cls, t, _actingCTFor[cls] || '', verifiedName),
        });
        emailedTo.push(t + ' (acting CT for ' + cls + ')');
        emailedCount++;
      } catch (e) {}
    }
  }

  // Generate printable memo
  let memoUrl = '';
  if (plan.makeMemo) memoUrl = generateMemo(plan);

  return {success: true, savedRows: rows.length, emailedCount, emailedTo, memoUrl};
}

// v3.12 — read Teacher Emails tab; cache for the request
function _loadTeacherEmails() {
  const sh = SpreadsheetApp.getActive().getSheetByName('Teacher Emails');
  if (!sh || sh.getLastRow() < 2) return {};
  const data = sh.getDataRange().getValues();
  const out = {};
  for (let i = 1; i < data.length; i++) {
    const [name, email] = data[i];
    if (name && email) out[String(name).trim()] = String(email).trim();
  }
  return out;
}

