// =============================================================
// v3.15 — In-app XML timetable upload (refresh from browser)
// Mirrors refresh_timetable.py logic using Apps Script's XmlService.
// Only Mr. Abhishek can use this endpoint (per user's explicit request).
// =============================================================
const REFRESH_ADMIN = 'Mr. Abhishek';
const DAY_NAMES = ['Mon','Tue','Wed','Thu','Fri','Sat'];   // ASC days bitmap LSB-left → Mon
const SKIP_CLASS_NAME_PATTERN = /Floor/;                   // non-pedagogical class names

function _requireRefreshAdmin(token) {
  const name = _requireAuth(token);
  if (name !== REFRESH_ADMIN) throw new Error('Only ' + REFRESH_ADMIN + ' can refresh the timetable.');
  return name;
}

function _parseAscXml(xmlText) {
  const doc = XmlService.parse(xmlText);
  const root = doc.getRootElement();
  if (root.getName() !== 'timetable') throw new Error('Not a valid timetable XML — root element is "' + root.getName() + '"');

  // Helper: walk children with a given name
  function children(parent, name) {
    return parent.getChildren(name);
  }
  function findTable(name) {
    const t = root.getChild(name);
    return t ? t.getChildren() : [];
  }
  function attr(el, n) { const a = el.getAttribute(n); return a ? a.getValue() : ''; }

  // periods → period num → {start, end}
  const periods = {};
  for (const p of children(root.getChild('periods') || {getChildren:()=>[]}, 'period')) {
    periods[attr(p, 'period')] = { start: attr(p, 'starttime'), end: attr(p, 'endtime') };
  }

  function pickLabel(el) {
    return (attr(el, 'short') || attr(el, 'name') || '').trim();
  }

  const subjects = {}; for (const s of findTable('subjects'))  subjects[attr(s,'id')] = pickLabel(s);
  const teachers = {}; for (const t of findTable('teachers'))  teachers[attr(t,'id')] = pickLabel(t);
  const classes  = {}; for (const c of findTable('classes'))   classes[attr(c,'id')]  = pickLabel(c);

  // Class teachers (from XML's class.teacherid)
  const classTeachers = {};
  for (const c of findTable('classes')) {
    const cname = pickLabel(c);
    if (!cname || SKIP_CLASS_NAME_PATTERN.test(cname)) continue;
    const tid = attr(c, 'teacherid');
    if (tid && teachers[tid]) classTeachers[cname] = teachers[tid];
  }

  // Lessons (id → {subject, classes[], teachers[]})
  const lessons = {};
  for (const l of findTable('lessons')) {
    const lid = attr(l, 'id');
    const sid = attr(l, 'subjectid');
    const cids = (attr(l, 'classids') || '').split(',').filter(Boolean);
    const tids = (attr(l, 'teacherids') || '').split(',').filter(Boolean);
    lessons[lid] = {
      subject: subjects[sid] || '',
      classes: cids.map(c => classes[c] || '').filter(Boolean),
      teachers: tids.map(t => teachers[t] || '').filter(Boolean),
    };
  }

  // Cards (period × days_bitmap × lesson)
  const flatTeacher = [];  // [Teacher, Day, Period, Start, End, Subject, Class, Room]
  const flatClass   = [];  // [Class, Day, Period, Start, End, Subject, Teacher, Room]
  for (const card of findTable('cards')) {
    const lesson = lessons[attr(card, 'lessonid')];
    if (!lesson) continue;
    const period = attr(card, 'period');
    const daysBits = attr(card, 'days');
    const start = (periods[period] && periods[period].start) || '';
    const end   = (periods[period] && periods[period].end)   || '';
    // v3.19 — mirror refresh_timetable.py: separate real classes from duty
    // (Floor) classes. Duty cards (lessons whose only classes are 1st/2nd/3rd
    // Floor) keep the teacher BUSY in Flat — Teacher so they aren't offered
    // as substitutes during duty periods. Floor labels don't go into Flat —
    // Class (Floor isn't a roster).
    const allClasses = lesson.classes.filter(Boolean);
    if (allClasses.length === 0) continue;
    const realClasses = allClasses.filter(c => !SKIP_CLASS_NAME_PATTERN.test(c));
    const dutyClasses = allClasses.filter(c =>  SKIP_CLASS_NAME_PATTERN.test(c));
    let klassForTeacher;
    if (realClasses.length > 0) {
      klassForTeacher = realClasses.join(' / ');
    } else {
      klassForTeacher = dutyClasses.map(c => '🛡 ' + c + ' (Duty)').join(' / ');
    }
    for (let i = 0; i < daysBits.length; i++) {
      if (daysBits[i] !== '1' || i >= DAY_NAMES.length) continue;
      const day = DAY_NAMES[i];
      for (const t of lesson.teachers) {
        if (!t) continue;
        // Always write Flat — Teacher (duty = busy)
        flatTeacher.push([t, day, period, start, end, lesson.subject, klassForTeacher, '']);
        // Flat — Class: only emit rows for REAL classes
        for (const k of realClasses) {
          flatClass.push([k, day, period, start, end, lesson.subject, t, '']);
        }
      }
    }
  }

  // Sorted unique sets
  const uTeachers = Object.values(teachers).filter(Boolean).sort();
  const uClasses  = Object.values(classes).filter(c => c && !SKIP_CLASS_NAME_PATTERN.test(c)).sort();
  const uSubjects = Object.values(subjects).filter(Boolean).sort();

  return {
    periods, classTeachers, teachers: uTeachers, classes: uClasses, subjects: uSubjects,
    flatTeacher, flatClass,
  };
}

// Build header + grid tabs from flat rows
function _buildTeacherGrid(flatTeacher, parsed) {
  const periodNums = Object.keys(parsed.periods).sort((a,b)=>+a-+b);
  const header = ['Teacher'].concat([].concat(...DAY_NAMES.map(d => periodNums.map(p => d+' P'+p))));
  const rows = [header];
  const lookup = {};
  for (const r of flatTeacher) lookup[r[0]+'|'+r[1]+'|'+r[2]] = r[5]+' '+r[6];
  for (const t of parsed.teachers) {
    const row = [t];
    for (const d of DAY_NAMES) for (const p of periodNums) row.push(lookup[t+'|'+d+'|'+p] || '');
    rows.push(row);
  }
  return rows;
}
function _buildClassGrid(flatClass, parsed) {
  const periodNums = Object.keys(parsed.periods).sort((a,b)=>+a-+b);
  const header = ['Class'].concat([].concat(...DAY_NAMES.map(d => periodNums.map(p => d+' P'+p))));
  const rows = [header];
  const lookup = {};
  for (const r of flatClass) lookup[r[0]+'|'+r[1]+'|'+r[2]] = r[5]+' ('+r[6]+')';
  for (const k of parsed.classes) {
    const row = [k];
    for (const d of DAY_NAMES) for (const p of periodNums) row.push(lookup[k+'|'+d+'|'+p] || '');
    rows.push(row);
  }
  return rows;
}

// Read current Flat — Teacher rows for diff
function _readCurrentFlatTeacher() {
  const sh = SpreadsheetApp.getActive().getSheetByName(FLAT_TEACHER_TAB);
  if (!sh || sh.getLastRow() < 2) return [];
  return sh.getRange(2, 1, sh.getLastRow()-1, 8).getValues().filter(r => r[0]);
}

function previewRefresh(xmlText, token) {
  _requireRefreshAdmin(token);
  if (!xmlText || xmlText.length < 100) throw new Error('XML appears empty or too small');
  const parsed = _parseAscXml(xmlText);
  // Diff against current Flat — Teacher
  const current = _readCurrentFlatTeacher();
  const curTeachers = new Set(current.map(r => r[0]).filter(Boolean));
  // Flat — Teacher's Class column stores joined labels for multi-class lessons
  // (e.g. "IX A / IX B / IX C" for merged Games). Split them so the class-set
  // diff compares individual names against parsed.classes (which is individual).
  const curClasses = new Set();
  for (const r of current) {
    if (!r[6]) continue;
    for (const k of String(r[6]).split(' / ')) {
      const t = k.trim();
      if (!t || SKIP_CLASS_NAME_PATTERN.test(t)) continue;
      curClasses.add(t);
    }
  }
  const curSubjects = new Set(current.map(r => r[5]).filter(Boolean));
  const newTeachers = new Set(parsed.teachers);
  const newClasses  = new Set(parsed.classes);
  const newSubjects = new Set(parsed.subjects);

  function diff(curSet, newSet) {
    const added = [], removed = [];
    for (const x of newSet) if (!curSet.has(x)) added.push(x);
    for (const x of curSet) if (!newSet.has(x)) removed.push(x);
    return { added: added.sort(), removed: removed.sort() };
  }
  const tDiff = diff(curTeachers, newTeachers);
  const cDiff = diff(curClasses, newClasses);
  const sDiff = diff(curSubjects, newSubjects);

  // Cell diff (teacher, day, period) keys
  const curCells = {};
  for (const r of current) curCells[r[0]+'|'+r[1]+'|'+r[2]] = [r[5], r[6]];
  const newCells = {};
  for (const r of parsed.flatTeacher) newCells[r[0]+'|'+r[1]+'|'+r[2]] = [r[5], r[6]];
  let added = 0, removed = 0, changed = 0;
  for (const k in newCells) {
    if (!(k in curCells)) added++;
    else if (curCells[k][0] !== newCells[k][0] || curCells[k][1] !== newCells[k][1]) changed++;
  }
  for (const k in curCells) if (!(k in newCells)) removed++;

  // Class Teacher diff (XML class.teacherid vs current Class Teachers tab)
  const ctTab = SpreadsheetApp.getActive().getSheetByName('Class Teachers');
  const curCT = {};
  if (ctTab && ctTab.getLastRow() > 1) {
    const ctData = ctTab.getRange(2, 1, ctTab.getLastRow()-1, 2).getValues();
    for (const r of ctData) if (r[0]) curCT[r[0]] = r[1] || '';
  }
  const ctChanges = [];
  for (const cls in parsed.classTeachers) {
    if (curCT[cls] !== parsed.classTeachers[cls]) {
      ctChanges.push({ class: cls, current: curCT[cls] || '(none)', new: parsed.classTeachers[cls] });
    }
  }

  return {
    counts: {
      curTeachers: curTeachers.size, newTeachers: newTeachers.size,
      curClasses: curClasses.size,   newClasses: newClasses.size,
      curSubjects: curSubjects.size, newSubjects: newSubjects.size,
      curCells: current.length, newCells: parsed.flatTeacher.length,
      cellAdded: added, cellRemoved: removed, cellChanged: changed,
    },
    teachers: tDiff,
    classes:  cDiff,
    subjects: sDiff,
    ctChanges: ctChanges,
    periodCount: Object.keys(parsed.periods).length,
  };
}

function applyRefresh(xmlText, token) {
  const verifiedName = _requireRefreshAdmin(token);
  const parsed = _parseAscXml(xmlText);
  const ss = SpreadsheetApp.getActive();

  // Write 4 schedule tabs + Class Teachers
  const targets = [
    {tab: FLAT_TEACHER_TAB, header: ['Teacher','Day','Period','Start','End','Subject','Class','Room'], rows: parsed.flatTeacher},
    {tab: 'Flat — Class',    header: ['Class','Day','Period','Start','End','Subject','Teacher','Room'], rows: parsed.flatClass},
    {tab: 'Teacher-wise Grid', rows: _buildTeacherGrid(parsed.flatTeacher, parsed)},
    {tab: 'Class-wise Grid',   rows: _buildClassGrid(parsed.flatClass, parsed)},
  ];

  for (const t of targets) {
    let sh = ss.getSheetByName(t.tab);
    if (!sh) sh = ss.insertSheet(t.tab);
    sh.clear();   // also clears stale number formats from prior uploads
    const rows = t.header ? [t.header].concat(t.rows) : t.rows;
    if (rows.length > 0) {
      // Apps Script setValues() coerces time-like strings ("8:00") into Date
      // values anchored at the Sheets epoch (1899-12-30). Force Start/End columns
      // to plain-text format BEFORE writing so they stay as strings.
      if (t.header && t.header[3] === 'Start' && t.header[4] === 'End') {
        sh.getRange(1, 4, rows.length, 2).setNumberFormat('@');
      }
      sh.getRange(1, 1, rows.length, rows[0].length).setValues(rows);
    }
    if (t.header) {
      sh.getRange(1, 1, 1, t.header.length).setFontWeight('bold').setBackground('#0041a3').setFontColor('#ffffff');
    }
  }

  // Class Teachers tab — per user's choice (v3.15), REWRITTEN from XML
  // (will revert V-C back to whatever XML says; user is aware)
  let ctSh = ss.getSheetByName('Class Teachers');
  if (!ctSh) ctSh = ss.insertSheet('Class Teachers');
  ctSh.clearContents();
  const CT_ORDER = ['Nur','Nursery','LKG','UKG','Pre-Nursery','KG'];
  const LEVEL_ORDER = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII'];
  function ctSortKey(name) {
    const parts = String(name).split(' ');
    const lvl = parts[0]; const sec = parts[1] || '';
    let i = CT_ORDER.indexOf(lvl);
    if (i >= 0) return [0, i, sec];
    i = LEVEL_ORDER.indexOf(lvl);
    if (i >= 0) return [1, i, sec];
    return [9, 99, name];
  }
  const ctRows = [['Class', 'Class Teacher']];
  const entries = Object.entries(parsed.classTeachers).sort((a, b) => {
    const ka = ctSortKey(a[0]); const kb = ctSortKey(b[0]);
    for (let i = 0; i < ka.length; i++) {
      if (ka[i] < kb[i]) return -1;
      if (ka[i] > kb[i]) return  1;
    }
    return 0;
  });
  for (const [cls, t] of entries) ctRows.push([cls, t]);
  ctSh.getRange(1, 1, ctRows.length, 2).setValues(ctRows);
  ctSh.getRange(1, 1, 1, 2).setFontWeight('bold').setBackground('#0041a3').setFontColor('#ffffff');

  // v3.17 — sync Teacher Emails tab: add any XML teachers not yet present
  // (blank email). Preserve existing emails. Never delete rows. Keeps
  // getData()'s "all teachers" union complete for new hires.
  let teSh = ss.getSheetByName('Teacher Emails');
  if (!teSh) {
    teSh = ss.insertSheet('Teacher Emails');
    teSh.getRange(1, 1, 1, 2).setValues([['Teacher', 'Email']])
         .setFontWeight('bold').setBackground('#0041a3').setFontColor('#ffffff');
  }
  const _teExisting = {};
  if (teSh.getLastRow() > 1) {
    const teData = teSh.getRange(2, 1, teSh.getLastRow() - 1, 2).getValues();
    for (const [name, email] of teData) {
      if (name) _teExisting[String(name).trim()] = email || '';
    }
  }
  const _teToAdd = [];
  for (const t of parsed.teachers) {
    if (!(t in _teExisting)) _teToAdd.push([t, '']);
  }
  if (_teToAdd.length) {
    teSh.getRange(teSh.getLastRow() + 1, 1, _teToAdd.length, 2).setValues(_teToAdd);
  }

  // Audit log → Refresh History tab
  const histTab = 'Refresh History';
  let hist = ss.getSheetByName(histTab);
  if (!hist) {
    hist = ss.insertSheet(histTab);
    hist.getRange(1, 1, 1, 5).setValues([['Refreshed At','Refreshed By','Source','Teachers','Cells']])
      .setFontWeight('bold').setBackground('#0041a3').setFontColor('#ffffff');
  }
  const ts = Utilities.formatDate(new Date(), 'Asia/Kolkata', 'yyyy-MM-dd HH:mm:ss');
  hist.appendRow([ts, verifiedName, 'in-app XML upload', parsed.teachers.length, parsed.flatTeacher.length]);

  // Save backup of the raw XML to Drive (so we can roll back if needed)
  try {
    const folder = DriveApp.getRootFolder();
    folder.createFile('timetable-backup-' + Utilities.formatDate(new Date(), 'Asia/Kolkata', 'yyyy-MM-dd-HHmm') + '.xml',
                      xmlText, MimeType.PLAIN_TEXT);
  } catch (e) { /* non-fatal */ }

  return {
    success: true,
    teachers: parsed.teachers.length,
    classes: parsed.classes.length,
    cells: parsed.flatTeacher.length,
    classTeachers: Object.keys(parsed.classTeachers).length,
  };
}

function generateMemo(plan) {
  const title = 'Substitution — ' + plan.date + ' (' + plan.day + ')';
  const doc = DocumentApp.create(title);
  const body = doc.getBody();
  body.setMarginTop(22).setMarginBottom(22).setMarginLeft(28).setMarginRight(28);

  const NAVY  = '#0041a3';
  const GREY  = '#f3f4f6';
  const BORDR = '#d1d5db';

  let dateLabel = plan.date;
  try {
    const d = new Date(plan.date + 'T00:00:00');
    if (!isNaN(d.getTime())) {
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const weekdays = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      dateLabel = weekdays[d.getDay()] + ', ' + d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
    }
  } catch (e) {}

  const SZ = 8;

  // 1. School header — compact bold centered
  const school = body.appendParagraph('G.D. Goenka Public School, Darbhanga');
  school.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
  school.editAsText().setBold(true).setFontSize(11);
  school.setLineSpacing(1.0);
  school.setSpacingAfter(0);
  school.setSpacingBefore(0);

  // 2. SUBSTITUTION banner — 1-cell borderless table for full-width navy background
  const banTable = body.appendTable([['SUBSTITUTION']]);
  const banCell = banTable.getRow(0).getCell(0);
  banCell.setBackgroundColor(NAVY);
  banCell.getChild(0).asParagraph().setAlignment(DocumentApp.HorizontalAlignment.CENTER);
  banCell.editAsText().setForegroundColor('#ffffff').setBold(true).setFontSize(SZ + 1);
  banCell.setPaddingTop(1).setPaddingBottom(1);
  banTable.setBorderColor(NAVY).setBorderWidth(0);

  // 3. Date + Day meta row — 2-cell compact table
  const metaTable = body.appendTable([['Date: ' + dateLabel, 'Day: ' + plan.day]]);
  metaTable.getRow(0).getCell(0).setBackgroundColor(GREY);
  metaTable.getRow(0).getCell(0).editAsText().setFontSize(SZ);
  metaTable.getRow(0).getCell(0).editAsText().setBold(0, 4, true);
  metaTable.getRow(0).getCell(1).setBackgroundColor(GREY);
  metaTable.getRow(0).getCell(1).editAsText().setFontSize(SZ);
  metaTable.getRow(0).getCell(1).editAsText().setBold(0, 3, true);
  metaTable.getRow(0).getCell(1).getChild(0).asParagraph()
    .setAlignment(DocumentApp.HorizontalAlignment.RIGHT);
  metaTable.setBorderColor(BORDR).setBorderWidth(0.5);
  metaTable.getRow(0).getCell(0).setPaddingTop(1).setPaddingBottom(1);
  metaTable.getRow(0).getCell(1).setPaddingTop(1).setPaddingBottom(1);

  // 4. Absent list — 1-cell compact table with pink tint
  const absentStr = (plan.absentTeachers && plan.absentTeachers.length)
    ? plan.absentTeachers.join(', ')
    : '(none)';
  const absTable = body.appendTable([['Teachers absent today: ' + absentStr]]);
  const absCell = absTable.getRow(0).getCell(0);
  absCell.setBackgroundColor('#fef2f2');
  absCell.editAsText().setFontSize(SZ);
  absCell.editAsText().setBold(0, 'Teachers absent today:'.length - 1, true);
  absTable.setBorderColor('#fecaca').setBorderWidth(0.5);
  absCell.setPaddingTop(1).setPaddingBottom(1);

  // 4b. Acting class teacher block
  const _planActingCT = plan.actingCT || {};
  const _planActingCTFor = plan.actingCTFor || {};
  const _actingEntries = Object.keys(_planActingCT)
    .filter(cls => _planActingCT[cls])
    .map(cls => {
      const forName = _planActingCTFor[cls] || '';
      return _planActingCT[cls] + ' — ' + cls + (forName ? ' (for ' + forName + ')' : '');
    });
  if (_actingEntries.length) {
    const actTable = body.appendTable([['Acting class teachers today: ' + _actingEntries.join(' · ')]]);
    const actCell = actTable.getRow(0).getCell(0);
    actCell.setBackgroundColor('#fefce8');
    actCell.editAsText().setFontSize(SZ);
    actCell.editAsText().setBold(0, 'Acting class teachers today:'.length - 1, true);
    actTable.setBorderColor('#fde68a').setBorderWidth(0.5);
    actCell.setPaddingTop(1).setPaddingBottom(1);
  }

  // 5. Main substitution table — compact, mirrors print memo
  const sorted = (plan.substitutions || []).slice().sort((a, b) => (+a.period) - (+b.period));
  const tableData = [['Period', 'Class', 'Subject', 'Absent Teacher', 'Substitute / Action', 'Signature']];
  let filled = 0, sup = 0, can = 0, pend = 0;
  for (const s of sorted) {
    let subDisplay;
    if (s.status === 'CANCELLED') { subDisplay = 'CANCELLED'; can++; }
    else if (s.status === 'SUPERVISED' && s.substitute) { subDisplay = s.substitute + ' (supervision)'; sup++; }
    else if (s.substitute) { subDisplay = s.substitute; filled++; }
    else { subDisplay = '— NOT ASSIGNED —'; pend++; }
    tableData.push([
      'P' + String(s.period || ''),
      String(s.class || ''),
      String(s.subject || ''),
      String(s.absent || ''),
      subDisplay,
      ''
    ]);
  }

  const table = body.appendTable(tableData);

  const hdr = table.getRow(0);
  for (let i = 0; i < 6; i++) {
    hdr.getCell(i).setBackgroundColor(NAVY);
    hdr.getCell(i).editAsText().setForegroundColor('#ffffff').setBold(true).setFontSize(SZ);
  }

  for (let r = 1; r < tableData.length; r++) {
    const row = table.getRow(r);
    const periodCell = row.getCell(0);
    periodCell.getChild(0).asParagraph().setAlignment(DocumentApp.HorizontalAlignment.CENTER);
    periodCell.editAsText().setBold(true).setFontSize(SZ);

    row.getCell(1).editAsText().setFontSize(SZ).setBold(true);
    row.getCell(2).editAsText().setFontSize(SZ);
    row.getCell(3).editAsText().setFontSize(SZ);
    const subCell = row.getCell(4);
    subCell.editAsText().setFontSize(SZ);
    if (sorted[r - 1].substitute && sorted[r - 1].status !== 'CANCELLED') {
      subCell.editAsText().setBold(true);
    }
    row.getCell(5).editAsText().setFontSize(SZ);

  }
  table.setBorderColor('#333333').setBorderWidth(0.5);

  // 6. Summary line — mirrors print memo
  const summaryParts = [];
  summaryParts.push(filled + ' filled');
  summaryParts.push(sup + ' supervised');
  summaryParts.push(can + ' cancelled');
  if (pend) summaryParts.push(pend + ' pending');
  const summary = body.appendParagraph(summaryParts.join('    '));
  summary.setFontSize(SZ - 1);
  summary.setForegroundColor('#374151');
  summary.setSpacingBefore(2);
  summary.setSpacingAfter(0);

  // 7. Principal signature — compact, right-aligned
  body.appendParagraph('').setSpacingBefore(18);
  const sigLine = body.appendParagraph('_____________________________');
  sigLine.setAlignment(DocumentApp.HorizontalAlignment.RIGHT);
  sigLine.setFontSize(SZ);
  const sig = body.appendParagraph('Principal');
  sig.setAlignment(DocumentApp.HorizontalAlignment.RIGHT);
  sig.editAsText().setBold(true).setFontSize(SZ + 1);

  doc.saveAndClose();
  const file = DriveApp.getFileById(doc.getId());
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return doc.getUrl();
}
