// =============================================================
// Auth — per-admin login (v3.5)
// Admins stored in Script Properties as JSON:
//   admins → {"Mr. Abhishek": {salt: "…", hash: "…"}, "Mr. Amit(IT)": {…}}
// Sessions stored as session_<token> properties with {name, expiresAt}.
// =============================================================
function _sha256Hex(s) {
  const bytes = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, s);
  let out = '';
  for (let i = 0; i < bytes.length; i++) {
    let b = bytes[i]; if (b < 0) b += 256;
    out += (b < 16 ? '0' : '') + b.toString(16);
  }
  return out;
}
function _hash(salt, password) { return _sha256Hex(salt + ':' + password); }

function _getAdmins() {
  const raw = PropertiesService.getScriptProperties().getProperty('admins');
  return raw ? JSON.parse(raw) : {};
}
function _setAdmins(map) {
  PropertiesService.getScriptProperties().setProperty('admins', JSON.stringify(map));
}

// --- Run these from the script editor to set up / manage admins ---
function addAdmin(name, password) {
  if (!name || !password) throw new Error('Both name and password required');
  const admins = _getAdmins();
  const salt = Utilities.getUuid();
  admins[name] = { salt: salt, hash: _hash(salt, password) };
  _setAdmins(admins);
  return 'OK — admin saved: ' + name;
}
function removeAdmin(name) {
  const admins = _getAdmins();
  delete admins[name];
  _setAdmins(admins);
  return 'OK — admin removed: ' + name;
}
function listAdmins() {
  return Object.keys(_getAdmins());
}
function _appendAudit(name, success, reason) {
  try {
    const ss = SpreadsheetApp.getActive();
    let sh = ss.getSheetByName(LOGIN_AUDIT_TAB);
    if (!sh) {
      sh = ss.insertSheet(LOGIN_AUDIT_TAB);
      sh.getRange(1, 1, 1, 4).setValues([['Timestamp (IST)', 'Name', 'Result', 'Detail']])
        .setFontWeight('bold').setBackground('#1a3c6e').setFontColor('#ffffff');
      sh.setFrozenRows(1);
    }
    const ts = Utilities.formatDate(new Date(), 'Asia/Kolkata', 'yyyy-MM-dd HH:mm:ss');
    sh.appendRow([ts, name || '(blank)', success ? '✓ Login' : '✗ Failed', reason || '']);
  } catch (e) {
    // never block auth on logging failures
  }
}

// --- Client-callable auth functions ---
function login(name, password) {
  const admins = _getAdmins();
  const a = admins[name];
  if (!a) { _appendAudit(name, false, 'unknown admin'); return { success: false, error: 'Invalid name or password.' }; }
  if (a.hash !== _hash(a.salt, password)) { _appendAudit(name, false, 'wrong password'); return { success: false, error: 'Invalid name or password.' }; }
  const token = Utilities.getUuid();
  const expiresAt = new Date().getTime() + SESSION_MS;
  PropertiesService.getScriptProperties().setProperty('session_' + token, JSON.stringify({ name: name, expiresAt: expiresAt }));
  _appendAudit(name, true, '');
  return { success: true, token: token, name: name, expiresAt: expiresAt };
}

function verifyToken(token) {
  if (!token) return { valid: false };
  const raw = PropertiesService.getScriptProperties().getProperty('session_' + token);
  if (!raw) return { valid: false };
  let data;
  try { data = JSON.parse(raw); } catch (e) { return { valid: false }; }
  if (!data.expiresAt || data.expiresAt < new Date().getTime()) {
    PropertiesService.getScriptProperties().deleteProperty('session_' + token);
    return { valid: false };
  }
  return { valid: true, name: data.name, expiresAt: data.expiresAt };
}

function logout(token) {
  if (token) PropertiesService.getScriptProperties().deleteProperty('session_' + token);
  return { success: true };
}

function _requireAuth(token) {
  const r = verifyToken(token);
  if (!r.valid) throw new Error('Session expired. Please log in again.');
  return r.name;
}

